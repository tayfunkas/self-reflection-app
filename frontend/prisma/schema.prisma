// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                @id @default(autoincrement())
  email               String             @unique
  emailVerified       DateTime?          @map("email_verified")
  passwordHash        String?            @map("password_hash")

  name                String?
  city                String?
  countryCode         String?            @map("country_code")
  timezone            String             @default("UTC")

  language            String             @default("en")

  marketingEmails     Boolean            @default(true) @map("marketing_emails")
  dailyQuestionEmails Boolean            @default(true) @map("daily_question_emails")
  dailyReflectionTime String             @default("00:00") @map("daily_reflection_time")

  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]

  questionDeliveries  QuestionDelivery[]
  responses           Response[]

  reflectionInsights  ReflectionInsight[]

  plusInterest Boolean @default(false) @map("plus_interest")

  @@map("users")
}

model Account {
  id                String   @id @default(cuid())
  userId            Int      @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Question {
  id                 Int                @id @default(autoincrement())
  text               String
  category           String
  depthLevel         Int                @map("depth_level")
  isActive           Boolean            @default(true) @map("is_active")
  canReappear        Boolean            @default(false) @map("can_reappear")
  reappearAfterDays  Int?               @map("reappear_after_days")
  firstPhaseAllowed  Boolean            @default(false) @map("first_phase_allowed")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  questionDeliveries QuestionDelivery[]
  responses          Response[]
  stats              QuestionStats?

  @@index([category])
  @@index([depthLevel])
  @@index([isActive])
  @@map("questions")
}

model QuestionDelivery {
  id          Int                  @id @default(autoincrement())
  userId      Int                  @map("user_id")
  questionId  Int                  @map("question_id")
  deliveredAt DateTime             @default(now()) @map("delivered_at")
  expiresAt   DateTime?            @map("expires_at")
  status      String
  emailSentAt DateTime? @map("email_sent_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question             @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response    Response?

  @@index([userId])
  @@index([questionId])
  @@index([status])
  @@index([deliveredAt])
  @@map("question_deliveries")
}

model Response {
  id           Int               @id @default(autoincrement())
  userId       Int               @map("user_id")
  questionId   Int               @map("question_id")
  deliveryId   Int               @unique @map("delivery_id")
  responseText String            @map("response_text")
  submittedAt  DateTime          @default(now()) @map("submitted_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  delivery     QuestionDelivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([submittedAt])
  @@map("responses")
}

model QuestionStats {
  questionId            Int      @id @map("question_id")
  deliveredCount        Int      @default(0) @map("delivered_count")
  answeredCount         Int      @default(0) @map("answered_count")
  responseDeletedCount  Int      @default(0) @map("response_deleted_count")

  question              Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_stats")
}

model ReflectionInsight {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")

  type      String   @default("first_five")
  content   String   @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt  DateTime? @map("viewed_at")

  @@index([userId])
  @@unique([userId, type])
  @@map("reflection_insights")
}